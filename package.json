{
  "name": "disapp",
  "version": "1.0.0",
  "private": true,
  "description": "Discord bot development made easy",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:bot": "pnpm --filter basic-bot dev",
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @disapp/core build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "db:push": "pnpm --filter @disapp/core db:push",
    "db:studio": "pnpm --filter @disapp/core db:studio"
  },
  "keywords": ["discord", "bot", "framework", "monorepo"],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
